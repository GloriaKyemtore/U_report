<nav class="navbar navbar-expand-lg navbar-institution">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">
      <i class="bi bi-megaphone-fill me-1"></i>U-Report
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="nav">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
        <% if (currentUser) { %>
          <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2 me-1"></i>Tableau de bord</a></li>
          <% if (currentUser.role !== ROLES.ADMIN) { %>
            <li class="nav-item"><a class="nav-link" href="/reclamations/nouvelle"><i class="bi bi-plus-circle me-1"></i>Nouvelle réclamation</a></li>
          <% } %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= currentUser.nom %>
              <span class="badge bg-primary-subtle text-primary ms-1"><%= currentUser.role %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><span class="dropdown-item-text small text-muted"><%= currentUser.email %></span></li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <form action="/logout?_method=POST" method="POST" class="px-2">
                  <button class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</button>
                </form>
              </li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/login">Connexion</a></li>
          <li class="nav-item"><a class="btn btn-primary btn-sm fw-semibold ms-lg-2" href="/register">Créer un compte</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<div class="container mt-3">
  <% success.forEach(function(m){ %>
    <div class="alert alert-success alert-dismissible fade show"><%= m %><button class="btn-close" data-bs-dismiss="alert"></button></div>
  <% }); %>
  <% error.forEach(function(m){ %>
    <div class="alert alert-danger alert-dismissible fade show"><%= m %><button class="btn-close" data-bs-dismiss="alert"></button></div>
  <% }); %>
</div>
