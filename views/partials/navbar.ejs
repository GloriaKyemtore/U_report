<nav class="navbar navbar-expand-lg navbar-institution">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">
      <i class="bi bi-megaphone-fill me-1"></i>U-Report
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="nav">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
        <% if (currentUser) { %>
          <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2 me-1"></i>Tableau de bord</a></li>
          <% if (currentUser.role !== ROLES.ADMIN) { %>
            <li class="nav-item"><a class="nav-link" href="/reclamations/nouvelle"><i class="bi bi-plus-circle me-1"></i>Nouvelle réclamation</a></li>
          <% } %>
          <li class="nav-item dropdown" id="notifDropdown">
            <a class="nav-link position-relative dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" id="notifBell" title="Notifications">
              <i class="bi bi-bell fs-5"></i>
              <span class="position-absolute badge rounded-pill bg-danger notif-badge<%= unreadCount > 0 ? '' : ' d-none' %>" id="notifBadge">
                <%= unreadCount %><span class="visually-hidden">notifications non lues</span>
              </span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end p-2" id="notifList" style="min-width: 320px; max-height: 340px; overflow-y: auto;">
              <% if (notifications.length === 0) { %>
                <li class="px-2 py-3 text-center text-muted small">Aucune notification</li>
              <% } else { %>
                <% notifications.forEach(function(n) { %>
                  <li><a class="dropdown-item small text-wrap" href="/reclamations/<%= n.id %>"><strong><%= n.ref %></strong> &mdash; <%= n.titre %></a></li>
                <% }); %>
              <% } %>
            </ul>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= currentUser.nom %>
              <span class="badge bg-primary-subtle text-primary ms-1"><%= currentUser.role %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><span class="dropdown-item-text small text-muted"><%= currentUser.email %></span></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/profil"><i class="bi bi-person-gear me-1"></i>Mon profil</a></li>
              <% if (currentUser.role === ROLES.ADMIN) { %>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <a class="dropdown-item d-flex justify-content-between align-items-center" href="/dashboard#demandesAdmin">
                    <span><i class="bi bi-person-plus me-1"></i>Demandes d'accès admin</span>
                    <% if (pendingAdminRequestCount > 0) { %>
                      <span class="badge bg-danger rounded-pill"><%= pendingAdminRequestCount %></span>
                    <% } %>
                  </a>
                </li>
              <% } %>
              <li><hr class="dropdown-divider"></li>
              <li>
                <form action="/logout?_method=POST" method="POST" class="px-2 mb-1">
                  <button class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</button>
                </form>
              </li>
              <li class="px-2">
                <button type="button" class="btn btn-sm btn-link text-danger w-100 text-decoration-none" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                  <i class="bi bi-trash3 me-1"></i>Supprimer mon compte
                </button>
              </li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/login">Connexion</a></li>
          <li class="nav-item"><a class="btn btn-primary btn-sm fw-semibold ms-lg-2" href="/register">Créer un compte</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<% if (currentUser) { %>
  <div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form action="/compte/supprimer" method="POST">
          <div class="modal-header">
            <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill text-danger me-1"></i>Supprimer mon compte</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <p class="small text-muted">
              Cette action est définitive : votre compte<% if (currentUser.role !== ROLES.ADMIN) { %> ainsi que vos réclamations<% } %>
              seront supprimés et ne pourront pas être récupérés.
            </p>
            <label for="raisonSuppression" class="form-label">Pourquoi souhaitez-vous supprimer votre compte ? <span class="text-danger">*</span></label>
            <textarea class="form-control" id="raisonSuppression" name="raison" rows="3" required placeholder="Expliquez brièvement la raison de votre départ..."></textarea>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash3 me-1"></i>Supprimer définitivement</button>
          </div>
        </form>
      </div>
    </div>
  </div>
<% } %>

<div class="container mt-3">
  <% success.forEach(function(m){ %>
    <div class="alert alert-success alert-dismissible fade show"><%= m %><button class="btn-close" data-bs-dismiss="alert"></button></div>
  <% }); %>
  <% error.forEach(function(m){ %>
    <div class="alert alert-danger alert-dismissible fade show"><%= m %><button class="btn-close" data-bs-dismiss="alert"></button></div>
  <% }); %>
</div>
