<%- include('../partials/head', { title: 'Mon tableau de bord' }) %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
      <h3 class="fw-bold mb-0">Mes réclamations</h3>
      <p class="text-muted mb-0">Bonjour <%= currentUser.nom %>, voici le suivi de vos demandes.</p>
    </div>
    <a href="/reclamations/nouvelle" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Nouvelle réclamation</a>
  </div>

  <div class="d-flex align-items-center gap-2 mb-4">
    <label class="form-label small mb-0 text-muted">Statut</label>
    <select id="statutFilter" class="form-select form-select-sm" style="width: auto;">
      <option value="" <%= statutFilter === '' ? 'selected' : '' %>>Tous</option>
      <% Object.values(STATUSES).forEach(function(s){ %>
        <option value="<%= s %>" <%= statutFilter === s ? 'selected' : '' %>><%= s %></option>
      <% }); %>
    </select>
  </div>

  <div id="complaintsContainer"><%- include('../partials/etudiant-cards', { complaints: complaints, statutFilter: statutFilter }) %></div>
  <div id="pagination"><%- include('../partials/pagination', { page: pagination.page, pages: pagination.pages }) %></div>
</div>

<%- include('../partials/footer', { scripts: '<script src="/js/dashboard-filter.js"></script>' }) %>
