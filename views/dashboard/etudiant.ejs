<%- include('../partials/head', { title: 'Mon tableau de bord' }) %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
      <h3 class="fw-bold mb-0">Mes réclamations</h3>
      <p class="text-muted mb-0">Bonjour <%= currentUser.nom %>, voici le suivi de vos demandes.</p>
    </div>
    <a href="/reclamations/nouvelle" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Nouvelle réclamation</a>
  </div>

  <% if (complaints.length === 0) { %>
    <div class="text-center py-5 bg-light rounded-3">
      <i class="bi bi-inbox display-4 text-muted"></i>
      <p class="text-muted mt-2">Vous n'avez encore déposé aucune réclamation.</p>
      <a href="/reclamations/nouvelle" class="btn btn-primary">Déposer ma première réclamation</a>
    </div>
  <% } else { %>
    <div class="row g-3">
      <% complaints.forEach(function(c){ %>
        <div class="col-md-6">
          <a href="/reclamations/<%= c.id %>" class="text-decoration-none">
            <div class="card ticket-card h-100 border-0 shadow-sm">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                  <span class="text-muted small"><%= c.ref %></span>
                  <span class="badge <%= STATUS_BADGE[c.statut] %>"><%= c.statut %></span>
                </div>
                <h6 class="fw-bold text-dark mt-1 mb-2"><%= c.titre %></h6>
                <div class="d-flex flex-wrap gap-2 small text-muted">
                  <span><i class="bi bi-tag me-1"></i><%= c.categorie %></span>
                  <span><i class="bi bi-chat me-1"></i><%= c.messages.length %></span>
                  <span><i class="bi bi-clock me-1"></i><%= formatDate(c.createdAt) %></span>
                </div>
              </div>
            </div>
          </a>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
