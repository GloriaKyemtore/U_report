<%- include('../partials/head', { title: 'Modifier ' + complaint.ref }) %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb small">
          <li class="breadcrumb-item"><a href="/dashboard">Tableau de bord</a></li>
          <li class="breadcrumb-item active">Modifier <%= complaint.ref %></li>
        </ol>
      </nav>
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h3 class="fw-bold mb-1"><i class="bi bi-pencil-square text-primary me-1"></i>Modifier la réclamation</h3>
          <p class="text-muted mb-4">Cette réclamation n'a pas encore été consultée par l'administration.</p>
          <form action="/reclamations/<%= complaint.id %>/modifier" method="POST">
            <div class="mb-3">
              <label class="form-label">Titre <span class="text-danger">*</span></label>
              <input type="text" name="titre" class="form-control" required maxlength="120" value="<%= complaint.titre %>">
            </div>
            <div class="row g-3">
              <div class="col-md-6 mb-3">
                <label class="form-label">Université <span class="text-danger">*</span></label>
                <input type="text" name="universite" class="form-control" required maxlength="120" value="<%= complaint.universite %>">
                <div class="form-text">C'est aussi le destinataire de la réclamation.</div>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Filière <span class="text-danger">*</span></label>
                <input type="text" name="filiere" class="form-control" required maxlength="120" value="<%= complaint.filiere %>">
              </div>
            </div>
            <div class="row g-3">
              <div class="col-md-6 mb-3">
                <label class="form-label">Catégorie</label>
                <select name="categorie" class="form-select">
                  <% categories.forEach(function(c){ %><option value="<%= c %>" <%= c === complaint.categorie ? 'selected' : '' %>><%= c %></option><% }); %>
                </select>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Priorité</label>
                <select name="priorite" class="form-select">
                  <% priorities.forEach(function(p){ %><option value="<%= p %>" <%= p === complaint.priorite ? 'selected' : '' %>><%= p %></option><% }); %>
                </select>
              </div>
            </div>
            <div class="mb-4">
              <label class="form-label">Description <span class="text-danger">*</span></label>
              <textarea name="description" class="form-control" rows="6" required><%= complaint.description %></textarea>
            </div>
            <div class="d-flex gap-2">
              <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Enregistrer les modifications</button>
              <a href="/reclamations/<%= complaint.id %>" class="btn btn-outline-secondary">Annuler</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
