<%- include('../partials/head', { title: 'Réinitialiser le mot de passe' }) %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h3 class="fw-bold mb-1">Réinitialiser le mot de passe</h3>
          <p class="text-muted mb-4">Choisissez un nouveau mot de passe pour votre compte.</p>
          <form action="/reset-password/<%= token %>" method="POST">
            <%- include('../partials/csrf') %>
            <div class="mb-3">
              <label class="form-label">Nouveau mot de passe</label>
              <div class="input-group">
                <input type="password" name="password" class="form-control" required minlength="8" autofocus>
                <button class="btn btn-outline-secondary toggle-password" type="button" tabindex="-1" title="Afficher/masquer le mot de passe"><i class="bi bi-eye"></i></button>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Confirmer le mot de passe</label>
              <div class="input-group">
                <input type="password" name="confirmPassword" class="form-control" required minlength="8">
                <button class="btn btn-outline-secondary toggle-password" type="button" tabindex="-1" title="Afficher/masquer le mot de passe"><i class="bi bi-eye"></i></button>
              </div>
            </div>
            <button class="btn btn-primary w-100">Réinitialiser le mot de passe</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
