<%- include('../partials/head', { title: 'Créer un compte' }) %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h3 class="fw-bold mb-1">Créer un compte</h3>
          <p class="text-muted mb-4">Étudiant ou administration universitaire.</p>
          <form action="/register" method="POST">
            <div class="mb-3">
              <label class="form-label">Nom complet</label>
              <input type="text" name="nom" class="form-control" required autofocus>
            </div>
            <div class="mb-3">
              <label class="form-label">Email</label>
              <input type="email" name="email" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Mot de passe</label>
              <input type="password" name="password" class="form-control" required minlength="6">
            </div>
            <div class="mb-3">
              <label class="form-label">Type de compte</label>
              <div class="d-flex gap-3">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="role" id="roleEtudiant" value="<%= ROLES.ETUDIANT %>" checked>
                  <label class="form-check-label" for="roleEtudiant">Étudiant</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="role" id="roleAdmin" value="<%= ROLES.ADMIN %>">
                  <label class="form-check-label" for="roleAdmin">Administrateur</label>
                </div>
              </div>
            </div>
            <div class="mb-3 d-none" id="codeAdminField">
              <label class="form-label">Code d'invitation administrateur</label>
              <input type="text" name="codeAdmin" class="form-control" autocomplete="off">
              <div class="form-text">Fourni par l'administration universitaire.</div>
            </div>
            <button class="btn btn-primary w-100">Créer mon compte</button>
          </form>
          <p class="text-center mt-3 mb-0">Déjà inscrit ? <a href="/login">Se connecter</a></p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer', { scripts: `
  <script>
    var roleAdmin = document.getElementById('roleAdmin');
    var roleEtudiant = document.getElementById('roleEtudiant');
    var codeAdminField = document.getElementById('codeAdminField');
    function toggleCodeAdmin() { codeAdminField.classList.toggle('d-none', !roleAdmin.checked); }
    roleAdmin.addEventListener('change', toggleCodeAdmin);
    roleEtudiant.addEventListener('change', toggleCodeAdmin);
  </script>
` }) %>
