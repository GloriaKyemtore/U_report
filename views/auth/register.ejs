<%- include('../partials/head', { title: 'Créer un compte' }) %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h3 class="fw-bold mb-1">Créer un compte</h3>
          <p class="text-muted mb-4">Étudiant ou administration universitaire.</p>
          <form action="/register" method="POST">
            <div class="mb-3">
              <label class="form-label">Nom complet</label>
              <input type="text" name="nom" class="form-control" required autofocus>
            </div>
            <div class="mb-3">
              <label class="form-label">Email</label>
              <input type="email" name="email" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label" for="telephoneInput">Numéro de téléphone <span class="text-muted fw-normal">(optionnel)</span></label>
              <input type="tel" id="telephoneInput" name="telephone" data-phone class="form-control" placeholder="70 00 00 00">
              <div class="form-text">Sélectionnez votre pays (drapeau) puis saisissez votre numéro.</div>
            </div>
            <div class="mb-3">
              <label class="form-label">Mot de passe</label>
              <div class="input-group">
                <input type="password" name="password" class="form-control" required minlength="8">
                <button class="btn btn-outline-secondary toggle-password" type="button" tabindex="-1" title="Afficher/masquer le mot de passe"><i class="bi bi-eye"></i></button>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Type de compte</label>
              <div class="d-flex gap-3">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="role" id="roleEtudiant" value="<%= ROLES.ETUDIANT %>" checked>
                  <label class="form-check-label" for="roleEtudiant">Étudiant</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="role" id="roleAdmin" value="<%= ROLES.ADMIN %>">
                  <label class="form-check-label" for="roleAdmin">Administrateur</label>
                </div>
              </div>
            </div>
            <div class="mb-3 d-none" id="motifAdminField">
              <label class="form-label">Motif de la demande</label>
              <textarea name="motif" class="form-control" rows="3" placeholder="Expliquez votre fonction et pourquoi vous avez besoin d'un accès administrateur..."></textarea>
              <div class="form-text">Votre demande sera examinée par un administrateur avant activation du compte.</div>
            </div>
            <button class="btn btn-primary w-100" id="submitBtn">Créer mon compte</button>
          </form>
          <p class="text-center mt-3 mb-0">Déjà inscrit ? <a href="/login">Se connecter</a></p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer', { scripts: `
  <script>
    var roleAdmin = document.getElementById('roleAdmin');
    var roleEtudiant = document.getElementById('roleEtudiant');
    var motifAdminField = document.getElementById('motifAdminField');
    var submitBtn = document.getElementById('submitBtn');
    function toggleMotifAdmin() {
      motifAdminField.classList.toggle('d-none', !roleAdmin.checked);
      submitBtn.textContent = roleAdmin.checked ? 'Envoyer ma demande' : 'Créer mon compte';
    }
    roleAdmin.addEventListener('change', toggleMotifAdmin);
    roleEtudiant.addEventListener('change', toggleMotifAdmin);
  </script>
` }) %>
