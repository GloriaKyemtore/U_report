<%- include('../partials/head', { title: 'Mot de passe oublié' }) %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h3 class="fw-bold mb-1">Mot de passe oublié</h3>
          <p class="text-muted mb-4">Indiquez votre email pour recevoir un lien de réinitialisation.</p>

          <% if (resetLink) { %>
            <div class="alert alert-success">
              Lien de réinitialisation généré (démo sans envoi d'email réel) :<br>
              <a href="<%= resetLink %>" class="fw-semibold"><%= resetLink %></a>
            </div>
          <% } else { %>
            <form action="/forgot-password" method="POST">
              <%- include('../partials/csrf') %>
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" required autofocus>
              </div>
              <button class="btn btn-primary w-100">Envoyer le lien de réinitialisation</button>
            </form>
          <% } %>

          <p class="text-center mt-3 mb-0"><a href="/login">Retour à la connexion</a></p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
