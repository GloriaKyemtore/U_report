<%- include('../partials/head', { title: 'Connexion' }) %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h3 class="fw-bold mb-1">Connexion</h3>
          <p class="text-muted mb-4">Accédez à votre espace U-Report.</p>
          <form action="/login" method="POST">
            <%- include('../partials/csrf') %>
            <div class="mb-3">
              <label class="form-label">Email</label>
              <input type="email" name="email" class="form-control" required autofocus>
            </div>
            <div class="mb-3">
              <div class="d-flex justify-content-between">
                <label class="form-label">Mot de passe</label>
                <a href="/forgot-password" class="small">Mot de passe oublié ?</a>
              </div>
              <div class="input-group">
                <input type="password" name="password" class="form-control" required>
                <button class="btn btn-outline-secondary toggle-password" type="button" tabindex="-1" title="Afficher/masquer le mot de passe"><i class="bi bi-eye"></i></button>
              </div>
            </div>
            <button class="btn btn-primary w-100">Se connecter</button>
          </form>
          <hr class="my-4">
          <div class="small text-muted">
            <div class="fw-semibold mb-1">Comptes de démonstration :</div>
            Admin : <code>admin@ureport.bf</code> / <code>admin123</code><br>
            Étudiant : <code>gloria@ureport.bf</code> / <code>etudiant123</code>
          </div>
          <p class="text-center mt-3 mb-0">Pas de compte ? <a href="/register">Créer un compte</a></p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
