MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ureport?retryWrites=true&w=majority
# Chaine aleatoire longue et secrete. Generer avec :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-avec-une-chaine-aleatoire-longue
# Mettre "production" une fois heberge (active les cookies securises HTTPS)
NODE_ENV=development
